{
  "name": "@geolocus/agent-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke": "tsx src/smoke.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" --max-warnings 0",
    "prettier": "prettier src test --write",
    "format": "pnpm prettier && pnpm lint",
    "check": "tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^1.0.0",
    "@ai-sdk/mcp": "^1.0.0",
    "ai": "^6.0.0",
    "express": "^5.2.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
